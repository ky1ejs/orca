#!/usr/bin/env bash
#
# Bootstrap an Orca worktree with isolated resources.
# Derives port and database name deterministically from the worktree path
# via a hash, then delegates to per-package bootstrap scripts.
#
# Usage:
#   scripts/bootstrap <worktree-path>
#
# Or from .orca/bootstrap (daemon-triggered):
#   scripts/bootstrap "$ORCA_WORKTREE_PATH"

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: scripts/bootstrap <worktree-path>" >&2
  exit 1
fi

WORKTREE_PATH="$1"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MAIN_REPO="$(cd "$SCRIPT_DIR/.." && pwd)"

# ─── Derive port and DB name from worktree path ──────────────────────

# Hash the worktree path to get a deterministic, collision-resistant value.
# Uses first 8 hex chars of SHA-256 → 4 billion values, mapped to port range.
HASH=$(echo -n "$WORKTREE_PATH" | shasum -a 256 | cut -c1-8)
HASH_INT=$((16#${HASH}))

# Port range: 4010–4999 (990 slots, avoids default 4000)
PORT=$(( 4010 + (HASH_INT % 990) ))
DB_NAME="orca_wt_${HASH}"

echo "Worktree: $(basename "$WORKTREE_PATH")"
echo "Port: $PORT, Database: $DB_NAME (hash: $HASH)"

# ─── Ensure Postgres is running ──────────────────────────────────────

if ! docker compose -f "$MAIN_REPO/docker-compose.yml" ps --status running 2>/dev/null | grep -q postgres; then
  echo "Starting Postgres..."
  docker compose -f "$MAIN_REPO/docker-compose.yml" up -d 2>&1
fi

# ─── Create database ─────────────────────────────────────────────────

docker compose -f "$MAIN_REPO/docker-compose.yml" exec -T postgres \
  psql -U postgres -c "CREATE DATABASE $DB_NAME;" 2>/dev/null || true
echo "Database ready: $DB_NAME"

# ─── Generate .env files ─────────────────────────────────────────────

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/${DB_NAME}"

# Backend .env
BACKEND_ENV="$WORKTREE_PATH/backend/.env"
if [[ -f "$MAIN_REPO/backend/.env" ]]; then
  cp "$MAIN_REPO/backend/.env" "$BACKEND_ENV"
else
  touch "$BACKEND_ENV"
fi

# Override PORT
if grep -q '^PORT=' "$BACKEND_ENV" 2>/dev/null; then
  sed -i '' "s|^PORT=.*|PORT=${PORT}|" "$BACKEND_ENV"
else
  echo "PORT=${PORT}" >> "$BACKEND_ENV"
fi

# Override DATABASE_URL
if grep -q '^DATABASE_URL=' "$BACKEND_ENV" 2>/dev/null; then
  sed -i '' "s|^DATABASE_URL=.*|DATABASE_URL=${DATABASE_URL}|" "$BACKEND_ENV"
else
  echo "DATABASE_URL=${DATABASE_URL}" >> "$BACKEND_ENV"
fi

# Ensure JWT_SECRET is set
if ! grep -q '^JWT_SECRET=' "$BACKEND_ENV" 2>/dev/null; then
  JWT_SECRET="dev-jwt-secret-$(openssl rand -hex 16)"
  echo "JWT_SECRET=${JWT_SECRET}" >> "$BACKEND_ENV"
fi

# Web .env
echo "VITE_BACKEND_PORT=${PORT}" > "$WORKTREE_PATH/web/.env"

echo "Environment files generated."

# ─── Install dependencies ────────────────────────────────────────────

echo "Installing dependencies..."
(cd "$WORKTREE_PATH/backend" && bun install) 2>&1
(cd "$WORKTREE_PATH/web" && bun install) 2>&1

# ─── Package-specific bootstrap ──────────────────────────────────────

echo "Bootstrapping backend..."
"$WORKTREE_PATH/backend/scripts/bootstrap"

echo "Bootstrapping web..."
"$WORKTREE_PATH/web/scripts/bootstrap"

echo "Bootstrap complete! Port: $PORT, DB: $DB_NAME"
