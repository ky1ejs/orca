#!/usr/bin/env bash
#
# Tear down an Orca worktree's isolated resources.
# Mirrors scripts/bootstrap — derives the same port/DB from the worktree path hash.
#
# Expects CWD to be the worktree root.

set -euo pipefail

WORKTREE_PATH="$(pwd)"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# ─── Derive DB name from worktree path (same hash as bootstrap) ──────

HASH=$(echo -n "$WORKTREE_PATH" | shasum -a 256 | cut -c1-8)
DB_NAME="orca_wt_${HASH}"

echo "Tearing down worktree: $(basename "$WORKTREE_PATH")"
echo "Database: $DB_NAME (hash: $HASH)"

# ─── Per-package teardown ────────────────────────────────────────────

if [[ -x backend/scripts/teardown ]]; then
  backend/scripts/teardown
fi

if [[ -x web/scripts/teardown ]]; then
  web/scripts/teardown
fi

# ─── Drop database ──────────────────────────────────────────────────

if docker compose -f "$REPO_ROOT/docker-compose.yml" ps --status running 2>/dev/null | grep -q postgres; then
  docker compose -f "$REPO_ROOT/docker-compose.yml" exec -T postgres \
    psql -U postgres -c "DROP DATABASE IF EXISTS $DB_NAME;" 2>/dev/null || true
  echo "Database dropped: $DB_NAME"
else
  echo "Postgres not running — skipping database cleanup"
fi

echo "Teardown complete."
