#!/usr/bin/env bash
#
# Tear down an Orca worktree's isolated resources.
# Mirrors scripts/bootstrap — derives the same port/DB from the worktree path hash.
#
# Usage:
#   scripts/teardown <worktree-path>

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: scripts/teardown <worktree-path>" >&2
  exit 1
fi

WORKTREE_PATH="$1"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MAIN_REPO="$(cd "$SCRIPT_DIR/.." && pwd)"

# ─── Derive DB name from worktree path (same hash as bootstrap) ──────

HASH=$(echo -n "$WORKTREE_PATH" | shasum -a 256 | cut -c1-8)
DB_NAME="orca_wt_${HASH}"

echo "Tearing down worktree: $(basename "$WORKTREE_PATH")"
echo "Database: $DB_NAME (hash: $HASH)"

# ─── Per-package teardown ────────────────────────────────────────────

if [[ -x "$WORKTREE_PATH/backend/scripts/teardown" ]]; then
  "$WORKTREE_PATH/backend/scripts/teardown"
fi

if [[ -x "$WORKTREE_PATH/web/scripts/teardown" ]]; then
  "$WORKTREE_PATH/web/scripts/teardown"
fi

# ─── Drop database ──────────────────────────────────────────────────

if docker compose -f "$MAIN_REPO/docker-compose.yml" ps --status running 2>/dev/null | grep -q postgres; then
  docker compose -f "$MAIN_REPO/docker-compose.yml" exec -T postgres \
    psql -U postgres -c "DROP DATABASE IF EXISTS $DB_NAME;" 2>/dev/null || true
  echo "Database dropped: $DB_NAME"
else
  echo "Postgres not running — skipping database cleanup"
fi

echo "Teardown complete."
