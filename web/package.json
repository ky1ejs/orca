{
  "name": "@orca/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "setup": "bun run codegen && node scripts/rebuild-native.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "bun run setup && bun run build:daemon && electron-vite dev",
    "build": "bun run setup && electron-vite build && bun run build:daemon",
    "build:daemon": "node scripts/build-daemon.mjs",
    "typecheck": "bun run codegen && tsc --noEmit",
    "test": "bun run setup && ELECTRON_RUN_AS_NODE=1 electron ./node_modules/.bin/vitest run",
    "validate": "bun run lint && bun run format:check && bun run knip && bun run typecheck && bun run test && bun run build",
    "build:mac": "bun run build && electron-builder --mac --config electron-builder.yml",
    "codegen": "graphql-codegen --config codegen.ts",
    "drizzle:generate": "drizzle-kit generate",
    "knip": "knip"
  },
  "dependencies": {
    "@urql/exchange-graphcache": "^9.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.8.3",
    "graphql": "^16.10.0",
    "graphql-sse": "^2.5.3",
    "node-pty": "^1.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0",
    "urql": "^4.2.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typed-document-node": "^5.0.12",
    "@graphql-codegen/typescript": "^4.1.2",
    "@graphql-codegen/typescript-operations": "^4.4.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.9",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.1",
    "knip": "^5.86.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "wonka": "^6.3.5"
  }
}
