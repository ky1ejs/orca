{
  "name": "@orca/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "prisma migrate deploy && bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "codegen": "graphql-codegen --config codegen.ts",
    "seed": "bun run src/scripts/seed.ts",
    "seed:dev": "bun run src/scripts/seed-dev.ts",
    "deploy": "fly deploy",
    "knip": "knip",
    "validate": "bun run lint && bun run format:check && bun run knip && bun run typecheck && bun run test"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "graphql": "^16.10.0",
    "graphql-yoga": "^5.10.6",
    "jose": "^6.2.1",
    "prisma": "^6.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.3",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-resolvers": "^5.1.7",
    "@types/bun": "^1.2.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.22.0",
    "knip": "^5.86.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
