DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orca
# Direct (non-pooled) database URL — used by Prisma for migrations.
# Required in production when DATABASE_URL goes through a connection pooler (e.g. Neon/PgBouncer).
# For local dev with Docker, this can be the same as DATABASE_URL.
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orca
JWT_SECRET=change-me-to-a-random-64-char-hex-string
INVITE_CODE=change-me-to-a-shared-invite-secret
PORT=4000
